<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegPendingRename" file_encoding="UTF_8">
  <mapping data_type="pending_rename">
    <description
    ><![CDATA[
Extracts entries from the `PendingFileRenameOperations` value in the `System` hive. It lists file rename operations that Windows will perform on the next reboot, capturing the original and target paths.

- Shows which files are scheduled for rename at startup.
]]>
    </description>
    <category>File System</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="old_name" />
      </description>
      <additional_description>
        <output_name value="new_name" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="old_name"
        parser="String"
        description="original file path scheduled for rename at next reboot"
      />

      <field
        input="new_name"
        parser="String"
        description="target file path after rename operation"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegSnapExclude" file_encoding="UTF_8">
  <mapping data_type="backup_exclude">
    <description
    ><![CDATA[
Extracts entries that Windows marks as excluded from Volume Shadow Copy Service (VSS) and backup operations, from the `System` hive.

- Provides a list of files/folders purposely omitted from snapshots.
- Includes the registry key location, modification time and security owner.
- Outputs data in a timeline‑compatible JSON‑L format for further analysis.
]]>
    </description>
    <category>File System</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="name" />
      </description>
      <additional_description>
        <output_name value="file_path" />
        <output_name value="type" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="type"
        parser="String"
        description="type of the excluded entry (e.g., file or folder)"
      />

      <field
        input="name"
        parser="String"
        description="display name of the excluded item"
      />

      <field
        input="file_path"
        parser="String"
        description="full filesystem path of the excluded file or folder"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>

  </mapping>
</plugin>

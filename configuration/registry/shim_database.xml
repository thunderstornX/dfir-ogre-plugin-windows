<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegShimDb" file_encoding="UTF_8">
  <mapping data_type="shim_db">
    <description
    ><![CDATA[
Extracts information about the Windows Application Compatibility Shim database stored in the `Software` hive. .

- Lists each shim database GUID with the registry keys that reference it.
- Provides the installation timestamp and the physical file path of the shim database.
]]>
    </description>
    <category>Services and Applications</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="target" />
      </description>
      <additional_description>
        <output_name value="file_path" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="file_path"
        parser="String"
        qualifier="FILE_PATH"
        description="filesystem path entry in the shim database file"
      />

      <array>
        <field
          input="target"
          parser="String"
          description="application compatibility target path associated with the shim database"
        />
      </array>

      <field
        input="install_time"
        parser="DateTime"
        display_name="Install time"
        qualifier="DATE_INSTALLATION"
        description="timestamp when the entry was installed"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>

  </mapping>
</plugin>

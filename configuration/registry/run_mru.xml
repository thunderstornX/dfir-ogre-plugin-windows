<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegRunMru" file_encoding="UTF_8">
  <mapping data_type="run_mru">
    <description
    ><![CDATA[
Extracts entries from the `RunMRU` in the `NTUser` hive, which stores commands typed in the `Windows + R` dialog.

- Captures every command a user manually launched via the Run dialog.
- Preserves the alphabetical index indicating the order of entry.
]]>
    </description>
    <category>Services and Applications</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="executable" />
      </description>
      <additional_description>
        <output_name value="index" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="executable"
        parser="String"
        qualifier="COMMAND_LINE"
        description="command line entered in the Windows + R Run dialog"
      />
      <field
        input="index"
        parser="String"
        description="alphabetical index (a‑z) indicating the entry’s position in the RunMRU list"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegAppCompatCache" file_encoding="UTF_8">
  <mapping data_type="app_compat_cache">
    <description
    ><![CDATA[
Extracts entries from the `AppCompatCache` value stored in the Windows `System` hive. It parses binary cache data, emitting each cached executable’s path, last‑write time, and associated registry metadata.

- Provides the original file path used by the system for compatibility checks.
- Shows when the cache entry was last updated, helping to infer program execution timelines.
]]>
    </description>
    <category>Services and Applications</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="path" />
      </description>
      <additional_description>

      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="index"
        parser="Int"
        description="sequential index of the cache entry"
      />

      <field
        input="path"
        parser="String"
        qualifier="FILE_PATH"
        description="file path of the cached executable"
      />

      <field
        input="modification_date"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Cache Record Modification"
        description="last write time of the cached executable"
      />

      <field
        input="flag1"
        parser="String"
        description="unknown 4‑byte flag data (Windows 8 AppCompatCache)"
      />

      <field
        input="flag2"
        parser="String"
        description="unknown 4‑byte flag data (Windows 8 AppCompatCache)"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

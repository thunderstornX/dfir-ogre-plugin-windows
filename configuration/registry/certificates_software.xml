<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegSystemCertificates" file_encoding="UTF_8">
  <mapping data_type="x509_cert">
    <description
    ><![CDATA[
Parses the Windows `Software` registry hive to collect system‑wide X509 certificates stored in the `Software` hive. It reads the binary certificate blobs, decodes them, and extracts key certificate attributes.

- Provides complete certificate details (subject, issuer, validity period, public‑key algorithm, fingerprint).
]]>
    </description>
    <category>System Information</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="subject" />
      </description>
      <additional_description>
        <output_name value="issuer" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="subject"
        parser="String"
        description="certificate subject distinguished name (RFC 4514 format)"
      />

      <field
        input="issuer"
        parser="String"
        description="certificate issuer distinguished name (RFC 4514 format)"
      />

      <field
        input="not_valid_before"
        parser="DateTime"
        display_name="Not valid before"
        description="certificate start‑of‑validity timestamp (not before)"
      />

      <field
        input="not_valid_after"
        parser="DateTime"
        display_name="Not valid after"
        description="certificate end‑of‑validity timestamp (not after)"
      />

      <field
        input="pub_key_algo"
        parser="String"
        description="public‑key algorithm name (e.g., rsaEncryption)"
      />

      <field
        input="pub_key_algo_oid"
        parser="String"
        description="OID of the public‑key algorithm"
      />

      <field
        input="fingerprint_sha256"
        parser="String"
        description="SHA‑256 fingerprint of the certificate (hex string)"
      />

      <field
        input="version"
        parser="String"
        description="X.509 certificate version"
      />

      <field
        input="serial_number"
        parser="String"
        description="certificate serial number (decimal string)"
      />

      <array>
        <object input="extensions">
          <field
            input="name"
            parser="String"
            description="human‑readable name of the extension"
          />
          <field
            input="oid"
            parser="String"
            description="object identifier (OID) of the extension"
          />
          <field
            input="critical"
            parser="String"
            description="whether the extension is marked critical (true/false)"
          />
          <field
            input="value"
            parser="String"
            description="string representation of the extension value"
          />
        </object>
      </array>

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegClsIdIUser" file_encoding="UTF_8">
  <mapping data_type="clsid">
    <description
    ><![CDATA[
Enumerates every user‑specific COM class identifier (CLSID) stored in the `UsrClass` hive.

- Provides a complete list of per‑user COM registrations.
- Captures the executable that implements the COM object.
- Records any alternate CLSID mapping via “TreatAs”.
]]>
    </description>
    <category>Windows Artefacts</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />


    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="description" />
      </description>
      <additional_description>
        <output_name value="executable" />
        <output_name value="treat_as" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="guid"
        parser="String"
        qualifier="APP_CLSID"
        description="lower‑cased CLSID identifying the COM class"
      />

      <field
        input="description"
        parser="String"
        description="human‑readable description of the COM class"
      />

      <field
        input="executable"
        parser="String"
        qualifier="FILE_PATH"
        description="path(s) to the binary(ies) implementing the CLSID (e.g., InprocServer32, LocalServer32)"
      />

      <field
        input="treat_as"
        parser="String"
        qualifier="APP_CLSID"
        description="CLS ID that this entry redirects to via TreatAs"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="RegNetworkConfig" file_encoding="UTF_8">
  <mapping data_type="network_config">
    <description
    ><![CDATA[
Extracts network settings from the Windows `System` hive.

- Shows static IP assignments when DHCP is disabled.
- Provides DHCP‑derived addresses and DNS when enabled.
]]>
    </description>
    <category>System Information</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='iso' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <related_user>
        <output_name value="key_security.owner_sid" />
      </related_user>
      <description>
        <output_name value="ip_address" />
        <output_name value="dns_suffix" />
        <output_name value="dhcp" />
      </description>
      <additional_description>
        <output_name value="network_mask" />
        <output_name value="gateway" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
        input="ip_address"
        parser="String"
        qualifier="IP_ADDRESS"
        description="IP address assigned to the network interface"
      />

      <field
        input="network_mask"
        parser="String"
        description="Subnet mask associated with the IP address"
      />

      <field
        input="dhcp"
        parser="Bool"
        escription="Indicates whether the interface obtains its configuration via DHCP (true = DHCP enabled)"
      />

      <field
        input="dhcp_server"
        parser="String"
        description="Address of the DHCP server that provided the configuration"
      />

      <field
        input="dns_suffix"
        parser="String"
        description="DNS suffix (domain) applied to the interface"
      />

      <field
        input="name_servers"
        parser="String"
        description="Comma‑separated list of DNS name‑server addresses"
      />

      <field
        input="gateway"
        parser="String"
        description="Default gateway IP address for the interface"
      />

      <!-- Registry Key data-->
      <field
        input="key_path"
        parser="String"
        qualifier="KEY_PATH"
        description="full registry key name"
      />
      <field
        input="key_modif_time"
        parser="DateTime"
        qualifier="DATE_MODIFICATION"
        display_name="Registry key last modification"
        description="last modification timestamp of the registry key"
      />
      <object input="key_security">
        <field
          input="owner_sid"
          parser="String"
          qualifier="USER_SID"
          description="SID of the user that owns the registry key"
        />
        <field
          input="group_sid"
          parser="String"
          description="SID of the group that owns the registry key"
        />
        <array>
          <field
            input="control_flags"
            parser="String"
            description="security descriptor control flags for the key"
          />
        </array>
        <object input="dacl_ace">
          <field
            input="ace_type"
            parser="String"
            description="type of ACE (e.g., allow, deny)"
          />
          <field
            input="account_sid"
            parser="String"
            description="SID of the account the ACE applies to"
          />
          <array>
            <field
              input="ace_flags"
              parser="String"
              description="ACE flags that modify inheritance or behavior"
            />
          </array>
          <array>
            <field
              input="rights"
              parser="String"
              description="permissions granted or denied by the ACE"
            />
          </array>
        </object>
      </object>
    </fields>
  </mapping>

</plugin>

<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="IeWebCache" file_encoding="UTF_8">
  <mapping data_type="ie_webcache_history">
    <description
        ><![CDATA[
Extracts browsing history records from Internet Explorer 10+ WebCache databases (WebCacheV01.dat).
The plugin queries the Containers and Container_X tables to retrieve URL visits with metadata.

- Url provides the visited web address.
- Filename and FileExtension indicate cached file details.
- Timestamps (SyncTime, CreationTime, ExpiryTime, ModifiedTime, AccessedTime) show activity timeline.
- AccessCount and SyncCount reveal frequency and synchronization patterns.
]]>
    </description>
    <category>Browser Artefacts</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='timestamp' />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="Standard" />
      <description>
        <output_name value="url" />
      </description>
      <additional_description>
        <output_name value="file_name" />
        <output_name value="access_count" />
        <output_name value="file_size" />
      </additional_description>
    </timeline>

    <!-- Fields -->
    <fields>
      <field
                input="file_size"
                parser="Int"
                description="Size of the cached file in bytes"
            />

      <field
                input="type"
                parser="Int"
                description="Record type identifier from WebCache"
            />

      <field
                input="flags"
                parser="Int"
                description="Flags associated with the cache entry"
            />

      <field
                input="access_count"
                parser="Int"
                description="Number of times this URL was accessed"
            />

      <field
                input="sync_count"
                parser="Int"
                description="Number of synchronization operations for this entry"
            />

      <field
                input="exemption_delta"
                parser="Int"
                description="Time offset exemption delta in seconds"
            />

      <field input="url" parser="String" description="Visited URL" />

      <field
                input="filename"
                parser="String"
                description="Cached file name (if applicable)"
            />

      <field
                input="file_extension"
                parser="String"
                description="File extension of the cached resource"
            />

      <field
                input="redirect_url"
                parser="String"
                description="Redirect target URL (if any)"
            />

      <field
                input="request_headers"
                parser="String"
                description="HTTP request headers (hex encoded)"
            />

      <field
                input="response_headers"
                parser="String"
                description="HTTP response headers (hex encoded)"
            />

      <field
                input="group"
                parser="String"
                description="Cache group identifier (hex encoded)"
            />

      <field
                input="sync_time"
                parser="DateTime"
                display_name="Sync Time"
                description="Last synchronization time in UTC"
            />

      <field
                input="creation_time"
                parser="DateTime"
                qualifier="DATE_CREATION"
                display_name="Creation Time"
                description="Entry creation timestamp in UTC"
            />

      <field
                input="expiry_time"
                parser="DateTime"
                display_name="Expiry Time"
                description="Expiration timestamp in UTC"
            />

      <field
                input="modified_time"
                parser="DateTime"
                qualifier="DATE_MODIFICATION"
                display_name="Modified Time"
                description="Last modification timestamp in UTC"
            />

      <field
                input="accessed_time"
                parser="DateTime"
                qualifier="DATE_ACCESS"
                display_name="Accessed Time"
                description="Last access timestamp in UTC"
            />

      <field
                input="post_check_time"
                parser="DateTime"
                display_name="Post Check Time"
                description="Time of last post-check validation in UTC"
            />
    </fields>
  </mapping>
</plugin>

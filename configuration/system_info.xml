<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="Regexp" file_encoding="IBM866">
  <mapping data_type="systeminfo">
    <description
    ><![CDATA[
Parses the Windows SystemInfo CSV file generated by the `systeminfo` command.
]]></description>
    <category>System Information</category>

    <!-- The CSV header is on line 1 → skip it -->
    <skip_lines value="1" />

    <!-- Fail the whole file if a line cannot be parsed -->
    <regexp_fail_policy value="Fail" />

    <!-- Default date pattern for the two date fields -->
    <default_date_pattern value="%d/%m/%Y, %H:%M:%S" />

    <!-- Regular expression that captures every column -->
    <regex>
    <![CDATA[^(?:"(?P<host_name>[^"]*)"\s*,\s*)"(?P<os_name>[^"]*)"\s*,\s*"(?P<os_version>[^"]*)"\s*,\s*"(?P<os_manufacturer>[^"]*)"\s*,\s*"(?P<os_configuration>[^"]*)"\s*,\s*"(?P<os_build_type>[^"]*)"\s*,\s*"(?P<registered_owner>[^"]*)"\s*,\s*"(?P<registered_organization>[^"]*)"\s*,\s*"(?P<product_id>[^"]*)"\s*,\s*"(?P<original_install_date>[^"]*)"\s*,\s*"(?P<system_boot_time>[^"]*)"\s*,\s*"(?P<system_manufacturer>[^"]*)"\s*,\s*"(?P<system_model>[^"]*)"\s*,\s*"(?P<system_type>[^"]*)"\s*,\s*"(?P<processors>[^"]*)"\s*,\s*"(?P<bios_version>[^"]*)"\s*,\s*"(?P<windows_directory>[^"]*)"\s*,\s*"(?P<system_directory>[^"]*)"\s*,\s*"(?P<boot_device>[^"]*)"\s*,\s*"(?P<system_locale>[^"]*)"\s*,\s*"(?P<input_locale>[^"]*)"\s*,\s*"(?P<time_zone>[^"]*)"\s*,\s*"(?P<total_physical_memory>[^"]*)"\s*,\s*"(?P<available_physical_memory>[^"]*)"\s*,\s*"(?P<virtual_memory_max_size>[^"]*)"\s*,\s*"(?P<virtual_memory_available>[^"]*)"\s*,\s*"(?P<virtual_memory_in_use>[^"]*)"\s*,\s*"(?P<page_file_location>[^"]*)"\s*,\s*"(?P<domain>[^"]*)"\s*,\s*"(?P<logon_server>[^"]*)"\s*,\s*"(?P<hotfix>[^"]*)"\s*,\s*"(?P<network_cards>[^"]*)"\s*,\s*"(?P<hyper_v_requirements>[^"]*)"
]]>
    </regex>

    <timeline>
      <timeline_type value="Standard" />
      <description>
        <output_name value="host_name" />
      </description>
      <additional_description>
        <output_name value="os_name" />
        <output_name value="os_version" />
      </additional_description>
    </timeline>

    <fields>
      <field
        input="host_name"
        parser="String"
        description="Hostname of the machine"
      />
      <field
        input="os_name"
        parser="String"
        description="Operating system name"
      />
      <field
        input="os_version"
        parser="String"
        description="Operating system version"
      />
      <field
        input="os_manufacturer"
        parser="String"
        description="OS manufacturer"
      />
      <field
        input="os_configuration"
        parser="String"
        description="OS configuration (e.g., Standalone Server)"
      />
      <field
        input="os_build_type"
        parser="String"
        description="OS build type"
      />
      <field
        input="registered_owner"
        parser="String"
        description="Registered owner of the OS"
      />
      <field
        input="registered_organization"
        parser="String"
        description="Registered organization"
      />
      <field input="product_id" parser="String" description="Product ID" />
      <field
        input="original_install_date"
        parser="String"
        description="Original install date of the OS"
      />
      <field
        input="system_boot_time"
        parser="String"
        description="System boot time"
      />
      <field
        input="system_manufacturer"
        parser="String"
        description="System manufacturer"
      />
      <field input="system_model" parser="String" description="System model" />
      <field
        input="system_type"
        parser="String"
        description="System type (e.g., x64‑based PC)"
      />
      <field
        input="processors"
        parser="String"
        description="Processor description"
      />
      <field
        input="bios_version"
        parser="String"
        description="BIOS version string"
      />
      <field
        input="windows_directory"
        parser="String"
        description="Path to the Windows directory"
      />
      <field
        input="system_directory"
        parser="String"
        description="Path to the System directory"
      />
      <field
        input="boot_device"
        parser="String"
        description="Boot device identifier"
      />
      <field
        input="system_locale"
        parser="String"
        description="System locale setting"
      />
      <field
        input="input_locale"
        parser="String"
        description="Input locale setting"
      />
      <field
        input="time_zone"
        parser="String"
        description="Time zone description"
      />
      <field
        input="total_physical_memory"
        parser="String"
        description="Total physical memory"
      />
      <field
        input="available_physical_memory"
        parser="String"
        description="Available physical memory"
      />
      <field
        input="virtual_memory_max_size"
        parser="String"
        description="Maximum size of virtual memory"
      />
      <field
        input="virtual_memory_available"
        parser="String"
        description="Available virtual memory"
      />
      <field
        input="virtual_memory_in_use"
        parser="String"
        description="Virtual memory currently in use"
      />
      <field
        input="page_file_location"
        parser="String"
        description="Location(s) of page file(s)"
      />
      <field input="domain" parser="String" description="Domain name" />
      <field input="logon_server" parser="String" description="Logon server" />
      <field input="hotfix" parser="String" description="Installed hotfixes" />
      <field
        input="network_cards"
        parser="String"
        description="Network card(s) information"
      />
      <field
        input="hyper_v_requirements"
        parser="String"
        description="Hyper‑V requirement information"
      />
    </fields>
  </mapping>
</plugin>

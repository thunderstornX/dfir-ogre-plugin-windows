<?xml version="1.0" encoding="UTF-8" ?>
<plugin parser="USNInfo" file_encoding="UTF_8">
  <mapping data_type="usninfo">
    <description
    ><![CDATA[
Parses the CSV export of the Windows USN Journal. It extracts metadata for every change to a file or directory. Each entry provides identifiers, timestamps, attribute flags and the reason for the change.

- Reveals the exact moment a file was created, modified, deleted or renamed.
- Supplies the unique FRN (File Reference Number) split into sequence / record numbers, enabling correlation of multiple events for the same object.
- Lists granular attribute flags (archive, hidden, system, etc.) and change reasons (e.g., data write, security change).
]]>
    </description>
    <category>File System</category>
    <default_parser value="Ignore" />
    <default_date_pattern value='%Y-%m-%d %H:%M:%S.%3f' />
    <csv_delimiter value="," />

    <!-- Timeline definition -->
    <timeline>
      <timeline_type value="MacbMacb" />
      <description>
        <output_name value="file_path" />
      </description>
      <additional_description>
        <output_name value="sequence_number" />
        <output_name value="record_number" />
        <output_name value="parent_sequence_number" />
        <output_name value="parent_record_number" />
      </additional_description>
    </timeline>

    <fields>
      <field
        input="ComputerName"
        output="computer_name"
        parser="String"
        description="name of the host that generated the USN record"
      />

      <field
        input="USN"
        output="usn_number"
        qualifier="FS_USN"
        parser="IntRadix"
        radix="16"
        description="USN (Update Sequence Number) in hexadecimal"
      />

      <field input="FRN" parser="Extension">
        <field
          output="sequence_number"
          parser="Int"
          description="sequence part of the FRN"
        />
        <field
          output="record_number"
          parser="Int"
          description="record part of the FRN"
        />
      </field>

      <field input="ParentFRN" parser="Extension">
        <field
          output="parent_sequence_number"
          parser="Int"
          description="sequence part of the parent FRN"
        />
        <field
          output="parent_record_number"
          parser="Int"
          description="record part of the parent FRN"
        />
      </field>

      <field
        input="TimeStamp"
        output="timestamp"
        parser="DateTime"
        pattern="default"
        description="timestamp of the change recorded in the USN journal"
      />

      <field
        input="File"
        output="file"
        qualifier="FILE_NAME"
        parser="String"
        description="name of the file or directory (no path)"
      />

      <field
        input="FullPath"
        output="file_path"
        qualifier="FILE_PATH"
        parser="String"
        description="full path of the file or directory"
      />

      <field input="FileAttributes" output="file_name_flags" parser="Extension">
        <field
          output="file_attributes_archive"
          parser="Bool"
          description="archive attribute flag"
        />

        <field
          output="file_attributes_no_scrub_data"
          parser="Bool"
          description="no‑scrub‑data attribute flag"
        />

        <field
          output="file_attributes_compressed"
          parser="Bool"
          description="compressed attribute flag"
        />

        <field
          output="file_attributes_directory"
          parser="Bool"
          description="directory attribute flag"
        />

        <field
          output="file_attributes_encrypted"
          parser="Bool"
          description="encrypted attribute flag"
        />

        <field
          output="file_attributes_hidden"
          parser="Bool"
          description="hidden attribute flag"
        />

        <field
          output="file_attributes_not_content_indexed"
          parser="Bool"
          description="not‑content‑indexed attribute flag"
        />

        <field
          output="file_attributes_reparse_point"
          parser="Bool"
          description="reparse‑point attribute flag"
        />

        <field
          output="file_attributes_normal"
          parser="Bool"
          description="normal attribute flag"
        />

        <field
          output="file_attributes_offline"
          parser="Bool"
          description="offline attribute flag"
        />

        <field
          output="file_attributes_sparse_file"
          parser="Bool"
          description="sparse‑file attribute flag"
        />

        <field
          output="file_attributes_readonly"
          parser="Bool"
          description="read‑only attribute flag"
        />

        <field
          output="file_attributes_system"
          parser="Bool"
          description="system attribute flag"
        />

        <field
          output="file_attributes_temporary"
          parser="Bool"
          description="temporary attribute flag"
        />

        <field
          output="file_attributes_virtual"
          parser="Bool"
          description="virtual attribute flag"
        />

        <field
          output="file_attributes_recall_on_data_access"
          parser="Bool"
          description="recall‑on‑data‑access attribute flag"
        />

        <field
          output="file_attributes_device"
          parser="Bool"
          description="device attribute flag"
        />

        <field
          output="file_attributes_ea"
          parser="Bool"
          description="extended‑attributes (EA) attribute flag"
        />

        <field
          output="file_attributes_recall_on_open"
          parser="Bool"
          description="recall‑on‑open attribute flag"
        />

        <field
          output="file_attributes_pinned"
          parser="Bool"
          description="pinned attribute flag"
        />

        <field
          output="file_attributes_integrity_stream"
          parser="Bool"
          description="integrity‑stream attribute flag"
        />

        <field
          output="file_attributes_unpinned"
          parser="Bool"
          description="unpinned attribute flag"
        />

      </field>

      <field
        input="Reason"
        output="reason"
        parser="Split"
        split_by="|"
        description="reason codes describing why the USN entry was generated"
      />

      <field
        input="VolumeID"
        output="volume_id"
        parser="String"
        description="identifier of the volume on which the change occurred"
      />

      <field
        input="SnapshotID"
        output="snapshot_id"
        parser="String"
        description="identifier of the volume snapshot (if applicable)"
      />
    </fields>
  </mapping>

</plugin>
